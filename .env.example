# API key for POST /api/send (optional in development)
API_KEY=your-secret-api-key

# SMTP (required)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-user@example.com
SMTP_PASS=your-password

# Default sender when "from" is omitted in the request
SMTP_FROM=noreply@example.com
